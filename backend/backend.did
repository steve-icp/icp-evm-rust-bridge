type Result = variant { Ok : text; Err : text };
type Result_1 = variant { Ok : nat64; Err : text };
service : {
  call_decrease_count : () -> (Result);
  call_increase_count : () -> (Result);
  get_count : () -> (Result_1);
  get_stored_transaction_hashes : () -> (vec text);
  store_transaction_hash : (text) -> ();
}
